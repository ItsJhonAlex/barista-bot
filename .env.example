# Barista — environment variables (copy to .env and fill in; never commit real values)

# Node environment: development | production | test
NODE_ENV=development

# Discord application (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional: server (guild) id for instant slash-command registration during development.
# With it set, commands appear immediately in that server; without it they register globally
# (which can take up to ~1h to propagate). Enable Developer Mode in Discord to copy the id.
DISCORD_DEV_GUILD_ID=

# Data services
DATABASE_URL=postgres://barista:barista@localhost:5432/barista
REDIS_URL=redis://localhost:6379

# Auth (generate a long random string, >= 16 chars)
BETTER_AUTH_SECRET=

# Public URL of the dashboard SPA
DASHBOARD_URL=http://localhost:5173

# Backend (api) public URL and port
API_URL=http://localhost:3000
API_PORT=3000
